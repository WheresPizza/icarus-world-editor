{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "ICARUS Prospect Editor",
  "version": "0.1.6",
  "identifier": "com.icarus-prospect-editor",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "ICARUS Prospect Editor",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "fixedRuntime",
        "path": "./webview2-runtime/"
      },
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": false,
        "startMenuFolder": "ICARUS Prospect Editor",
        "headerImage": null,
        "sidebarImage": null
      },
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    },
    "shortDescription": "Manage, edit, and backup ICARUS prospect save files",
    "longDescription": "A desktop utility for the Steam game ICARUS. Browse your prospect files, edit metadata and world data (inventories, deployables, player state), and manage backups - all from a clean native UI.",
    "copyright": "",
    "category": "Utility",
    "license": "MIT"
  }
}
